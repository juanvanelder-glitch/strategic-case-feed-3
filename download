export default function StrategyFeed() {
  const [mode, setMode] = useState("feed"); // "feed" | "case"
  const [ci, setCi] = useState(0);
  const [si, setSi] = useState(0);
  const [anim, setAnim] = useState(false);
  const [animDir, setAnimDir] = useState(null);
  const [lastTap, setLastTap] = useState(0);
  const touchRef = useRef(null);
  const contentRef = useRef(null);
  const scrollRef = useRef(null);
  const nC = CASES.length;
  const nS = 5;
  const c = CASES[ci];
  const src = SOURCES[c.source];

  // Scroll to top on step or case change
  useEffect(() => {
    if (contentRef.current) contentRef.current.scrollTop = 0;
    if (scrollRef.current) scrollRef.current.scrollTop = 0;
  }, [si, ci, mode]);

  /* ─── Touch handling ─── */
  const handleTouchStart = (e) => {
    touchRef.current = { x: e.touches[0].clientX, y: e.touches[0].clientY, t: Date.now(), scrollTop: (mode === "feed" ? scrollRef.current?.scrollTop : contentRef.current?.scrollTop) || 0 };
  };

  const handleTouchEnd = (e) => {
    if (!touchRef.current || anim) return;
    const dx = e.changedTouches[0].clientX - touchRef.current.x;
    const dy = e.changedTouches[0].clientY - touchRef.current.y;
    const dt = Date.now() - touchRef.current.t;
    const ax = Math.abs(dx), ay = Math.abs(dy);

    if (mode === "feed") {
      // Tap detection (small movement, quick)
      if (ax < 15 && ay < 15 && dt < 300) {
        setMode("case"); setSi(0);
        touchRef.current = null;
        return;
      }
      // Swipe down → next case (finger moves up)
      if (ay > ax && ay > 80 && dt < 600) {
        if (dy < 0 && ci < nC - 1) {
          setAnimDir("up"); setAnim(true);
          setTimeout(() => { setCi(ci + 1); setAnimDir(null); setAnim(false); }, 380);
        } else if (dy > 0 && ci > 0) {
          setAnimDir("down"); setAnim(true);
          setTimeout(() => { setCi(ci - 1); setAnimDir(null); setAnim(false); }, 380);
        }
      }
    }

    if (mode === "case") {
      // Double tap detection
      const now = Date.now();
      if (ax < 15 && ay < 15 && dt < 300) {
        if (now - lastTap < 400) {
          setMode("feed"); setSi(0); setLastTap(0);
          touchRef.current = null;
          return;
        }
        setLastTap(now);
      }

      // Horizontal swipe → change step
      if (ax > ay * 1.3 && ax > 60 && dt < 500) {
        if (dx < 0 && si < nS - 1) {
          setAnimDir("sleft"); setAnim(true);
          setTimeout(() => { setSi(si + 1); setAnimDir(null); setAnim(false); }, 280);
        } else if (dx > 0 && si > 0) {
          setAnimDir("sright"); setAnim(true);
          setTimeout(() => { setSi(si - 1); setAnimDir(null); setAnim(false); }, 280);
        }
      }
    }
    touchRef.current = null;
  };

  // Keyboard
  useEffect(() => {
    const h = (e) => {
      if (mode === "feed") {
        if (e.key === "ArrowDown" && ci < nC - 1) { e.preventDefault(); setAnimDir("up"); setAnim(true); setTimeout(() => { setCi(ci + 1); setAnimDir(null); setAnim(false); }, 380); }
        if (e.key === "ArrowUp" && ci > 0) { e.preventDefault(); setAnimDir("down"); setAnim(true); setTimeout(() => { setCi(ci - 1); setAnimDir(null); setAnim(false); }, 380); }
        if (e.key === "Enter") { setMode("case"); setSi(0); }
      }
      if (mode === "case") {
        if (e.key === "ArrowRight" && si < nS - 1) { e.preventDefault(); setAnimDir("sleft"); setAnim(true); setTimeout(() => { setSi(si + 1); setAnimDir(null); setAnim(false); }, 280); }
        if (e.key === "ArrowLeft" && si > 0) { e.preventDefault(); setAnimDir("sright"); setAnim(true); setTimeout(() => { setSi(si - 1); setAnimDir(null); setAnim(false); }, 280); }
        if (e.key === "Escape") { setMode("feed"); setSi(0); }
      }
    };
    window.addEventListener("keydown", h); return () => window.removeEventListener("keydown", h);
  }, [mode, ci, si, nC, nS]);

  const cardTx = animDir === "up" ? "translateY(-105%)" : animDir === "down" ? "translateY(105%)" : "translateY(0)";
  const stepOp = animDir === "sleft" || animDir === "sright" ? 0 : 1;

  /* ─── FEED MODE ─── */
  if (mode === "feed") return (
    <div onTouchStart={handleTouchStart} onTouchEnd={handleTouchEnd}
      style={{ width: "100%", height: "100vh", background: "#08080A", overflow: "hidden", position: "relative", fontFamily: "'Space Grotesk',sans-serif", userSelect: "none" }}>
      <style>{fonts}</style>
      <style>{`
        *{box-sizing:border-box;margin:0;padding:0}
        @keyframes fadeInUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
        .cs::-webkit-scrollbar{width:2px}.cs::-webkit-scrollbar-track{background:transparent}.cs::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px}
      `}</style>
      <div style={{ position: "absolute", top: "-30%", left: "-20%", width: "140%", height: "55%", background: `radial-gradient(ellipse at center, ${src.color}12 0%, transparent 70%)`, pointerEvents: "none", transition: "background .5s" }} />

      {/* Top bar */}
      <div style={{ position: "absolute", top: 0, left: 0, right: 0, zIndex: 10, padding: "14px 18px 0" }}>
        <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between" }}>
          <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
            <div style={{ width: 24, height: 24, borderRadius: 6, background: "linear-gradient(135deg,#E63946,#7B68EE)", display: "flex", alignItems: "center", justifyContent: "center" }}>
              <span style={{ color: "#fff", fontSize: 12, fontWeight: 700 }}>△</span>
            </div>
            <span style={{ fontFamily: "'Newsreader',serif", fontSize: 17, fontWeight: 500, color: "#F0EDE8" }}>Strategy Feed</span>
          </div>
          <span style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 10, color: "rgba(255,255,255,.25)" }}>{ci + 1}/{nC}</span>
        </div>
      </div>

      {/* Full screen card */}
      <div style={{
        position: "absolute", top: 52, left: 14, right: 14, bottom: 60,
        transform: cardTx,
        transition: anim ? "transform .38s cubic-bezier(.22,1,.36,1), opacity .38s" : "none",
        opacity: anim ? 0 : 1,
      }}>
        <div style={{
          width: "100%", height: "100%", borderRadius: 18,
          background: "linear-gradient(165deg, #111114 0%, #0C0C0F 50%, #0F0F13 100%)",
          border: `1px solid ${src.color}20`,
          display: "flex", flexDirection: "column", overflow: "hidden", position: "relative",
        }}>
          <div style={{ position: "absolute", top: 0, right: 0, width: 100, height: 100, background: `radial-gradient(circle at top right, ${src.color}14 0%, transparent 70%)`, pointerEvents: "none" }} />

          {/* Card header */}
          <div style={{ padding: "20px 20px 0", flexShrink: 0 }}>
            <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 10 }}>
              <div style={{ width: 6, height: 6, borderRadius: "50%", background: src.color, boxShadow: `0 0 8px ${src.color}60` }} />
              <span style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 10, fontWeight: 500, color: src.accent, letterSpacing: ".06em", textTransform: "uppercase" }}>{src.name}</span>
              <span style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 9, color: "rgba(255,255,255,.2)" }}>{c.date}</span>
              <div style={{ marginLeft: "auto", padding: "2px 8px", borderRadius: 4, background: `${src.color}10`, border: `1px solid ${src.color}18` }}>
                <span style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 8, color: src.accent, textTransform: "uppercase" }}>{c.category}</span>
              </div>
            </div>
            <h1 style={{ fontFamily: "'Newsreader',serif", fontSize: "clamp(17px, 4vw, 24px)", fontWeight: 500, color: "#F0EDE8", lineHeight: 1.28, marginBottom: 14 }}>{c.title}</h1>
            <div style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 8, color: src.color, letterSpacing: ".1em", textTransform: "uppercase", marginBottom: 8 }}>◉ Contexte</div>
          </div>

          {/* Scrollable contexte */}
          <div ref={scrollRef} className="cs" style={{ flex: 1, overflow: "auto", padding: "0 20px 20px", WebkitOverflowScrolling: "touch" }}>
            <p style={{ fontFamily: "'Space Grotesk',sans-serif", fontSize: 13, lineHeight: 1.72, color: "rgba(240,237,232,.65)", fontWeight: 300, marginBottom: 12 }}>{c.contexte.body}</p>
            {c.contexte.keyFact && <div style={{ padding: "9px 12px", borderRadius: 9, background: `linear-gradient(135deg,${src.color}08,${src.color}03)`, border: `1px solid ${src.color}15`, marginBottom: 2 }}>
              <div style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 8, fontWeight: 500, color: src.color, letterSpacing: ".1em", textTransform: "uppercase", marginBottom: 3 }}>Key Fact</div>
              <div style={{ fontFamily: "'Space Grotesk',sans-serif", fontSize: 12, fontWeight: 500, color: src.accent, lineHeight: 1.45 }}>{c.contexte.keyFact}</div>
            </div>}
            <ClarifyingQuestions questions={c.contexte.clarifyingQs} sc={src.color} sa={src.accent} />

            {/* CTA */}
            <div style={{ marginTop: 20, padding: "14px", borderRadius: 12, background: `${src.color}10`, border: `1px solid ${src.color}25`, textAlign: "center" }}>
              <span style={{ fontFamily: "'Space Grotesk',sans-serif", fontSize: 13, fontWeight: 500, color: src.accent }}>Tap pour résoudre ce case →</span>
              <div style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 9, color: "rgba(255,255,255,.25)", marginTop: 4 }}>Framework · Deep Dive · Brainstorm · Pitch</div>
            </div>
          </div>
        </div>
      </div>

      {/* Bottom nav dots + hint */}
      <div style={{ position: "absolute", bottom: 0, left: 0, right: 0, padding: "10px 20px 16px", display: "flex", justifyContent: "space-between", alignItems: "center", zIndex: 10 }}>
        <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
          <div style={{ display: "flex", gap: 5 }}>
            {CASES.map((_, i) => (
              <div key={i} style={{ width: i === ci ? 18 : 6, height: 6, borderRadius: 3, background: i === ci ? SOURCES[CASES[i].source].color : "rgba(255,255,255,.12)", transition: "all .3s" }} />
            ))}
          </div>
        </div>
        <span style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 9, color: "rgba(255,255,255,.15)" }}>↕ swipe · tap pour ouvrir</span>
      </div>
    </div>
  );

  /* ─── CASE MODE ─── */
  const prog = ((si + 1) / nS) * 100;

  return (
    <div onTouchStart={handleTouchStart} onTouchEnd={handleTouchEnd}
      style={{ width: "100%", height: "100vh", background: "#08080A", overflow: "hidden", fontFamily: "'Space Grotesk',sans-serif", userSelect: "none", display: "flex", flexDirection: "column" }}>
      <style>{fonts}</style>
      <style>{`
        *{box-sizing:border-box;margin:0;padding:0}
        @keyframes fadeInUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
        .cs::-webkit-scrollbar{width:2px}.cs::-webkit-scrollbar-track{background:transparent}.cs::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px}
      `}</style>
      <div style={{ position: "absolute", top: "-30%", left: "-20%", width: "140%", height: "55%", background: `radial-gradient(ellipse at center, ${src.color}12 0%, transparent 70%)`, pointerEvents: "none" }} />

      {/* Top */}
      <div style={{ padding: "14px 18px 0", flexShrink: 0, zIndex: 10 }}>
        <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 8 }}>
          <button onClick={() => { setMode("feed"); setSi(0); }}
            style={{ background: "rgba(255,255,255,0.06)", border: "1px solid rgba(255,255,255,0.1)", borderRadius: 7, padding: "5px 10px", cursor: "pointer", display: "flex", alignItems: "center", gap: 4 }}>
            <span style={{ color: "rgba(255,255,255,.5)", fontSize: 13 }}>‹</span>
            <span style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 8, color: "rgba(255,255,255,.4)", textTransform: "uppercase" }}>Feed</span>
          </button>
          <div style={{ flex: 1, height: 2.5, background: "rgba(255,255,255,0.06)", borderRadius: 2, overflow: "hidden" }}>
            <div style={{ height: "100%", width: `${prog}%`, background: `linear-gradient(90deg,${src.color},${src.accent})`, borderRadius: 2, transition: "width .4s" }} />
          </div>
          <span style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 9, color: "rgba(255,255,255,.2)" }}>{si + 1}/{nS}</span>
        </div>

        <div style={{ display: "flex", alignItems: "center", gap: 6, marginBottom: 6 }}>
          <div style={{ width: 5, height: 5, borderRadius: "50%", background: src.color }} />
          <span style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 9, color: src.accent, textTransform: "uppercase" }}>{src.name}</span>
          <span style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 8, color: "rgba(255,255,255,.18)" }}>{c.category}</span>
        </div>

        <h1 style={{ fontFamily: "'Newsreader',serif", fontSize: "clamp(15px, 3.5vw, 20px)", fontWeight: 500, color: "#F0EDE8", lineHeight: 1.28, marginBottom: 10 }}>{c.title}</h1>

        <div style={{ display: "flex", gap: 3, marginBottom: 4 }}>
          {STEP_LABELS.map((l, i) => (
            <button key={i} onClick={() => { if (!anim) { setAnimDir(i > si ? "sleft" : "sright"); setAnim(true); setTimeout(() => { setSi(i); setAnimDir(null); setAnim(false); }, 250); } }}
              style={{ flex: 1, padding: "5px 2px", borderRadius: 5, border: "none", background: i === si ? `linear-gradient(135deg,${src.color}28,${src.color}12)` : "rgba(255,255,255,0.025)", cursor: "pointer", position: "relative", overflow: "hidden" }}>
              {i === si && <div style={{ position: "absolute", bottom: 0, left: 0, right: 0, height: 2, background: src.color }} />}
              <span style={{ display: "block", fontFamily: "'IBM Plex Mono',monospace", fontSize: 7.5, fontWeight: i === si ? 600 : 400, color: i === si ? src.accent : i < si ? "rgba(255,255,255,.3)" : "rgba(255,255,255,.15)", textTransform: "uppercase", whiteSpace: "nowrap", overflow: "hidden", textOverflow: "ellipsis" }}>
                {STEP_ICONS[i]} {l}
              </span>
            </button>
          ))}
        </div>
      </div>

      {/* Content */}
      <div ref={contentRef} className="cs" key={`${ci}-${si}`}
        style={{ flex: 1, overflow: "auto", padding: "14px 20px 40px", WebkitOverflowScrolling: "touch", opacity: stepOp, transition: "opacity .2s", animation: stepOp === 1 ? "fadeInUp .3s ease" : "none" }}>
        <StepContent c={c} si={si} sc={src.color} sa={src.accent} />
      </div>

      {/* Bottom */}
      <div style={{ padding: "8px 20px 14px", flexShrink: 0, display: "flex", justifyContent: "center", borderTop: "1px solid rgba(255,255,255,0.04)" }}>
        <span style={{ fontFamily: "'IBM Plex Mono',monospace", fontSize: 9, color: "rgba(255,255,255,.15)" }}>↔ swipe étapes · double tap pour revenir</span>
      </div>
    </div>
  );
}
